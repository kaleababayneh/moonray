{
  "name": "@moonray/contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "compact": "compact compile src/slicer.compact src/managed/slicer",
    "compact:fast": "compact compile --skip-zk src/slicer.compact src/managed/slicer",
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/slicer.compact ./dist/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.16.0"
  },
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4",
    "@moonray/engine": "*"
  }
}